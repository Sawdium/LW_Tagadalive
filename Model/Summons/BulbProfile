/*
 * BulbProfile - Static definition of a bulb type using game API
 * Uses getBulbCharacteristics() to fetch stat ranges dynamically.
 */
class BulbProfile {
	integer bulbType       // BULB_LIGHTNING, etc. (game constant)
	integer summonChip     // CHIP_LIGHTNING_BULB
	Map<integer, Array<integer>>? characs = null  // cached from getBulbCharacteristics()

	constructor(integer bulbType, integer summonChip) {
		this.bulbType = bulbType
		this.summonChip = summonChip
	}

	/*
	 * Compute bulb stats based on summoner level
	 * Formula: floor(min + (max - min) * min(300, level) / 300)
	 * Fetches stat ranges from game API on first call (40 ops, cached).
	 */
	BulbStats computeStats(integer summonerLevel) {
		if (this.characs == null) {
			this.characs = getBulbCharacteristics(this.summonChip)
		}
		Map<integer, Array<integer>> c = this.characs!
		real ratio = min(300, summonerLevel) / 300.0
		// Keys: 0=life, 1=tp, 2=mp, 3=str, 4=agi, 6=wsd, 11=mgc, 12=snc, 13=rst
		// TODO: replace with CHARAC_* constants when they become available
		return BulbStats(
			BulbProfile._interp(c[0], ratio),   // life
			BulbProfile._interp(c[3], ratio),   // str
			BulbProfile._interp(c[4], ratio),   // agi
			BulbProfile._interp(c[2], ratio),   // mp
			BulbProfile._interp(c[1], ratio),   // tp
			BulbProfile._interp(c[12], ratio),  // snc
			BulbProfile._interp(c[6], ratio),   // wsd
			BulbProfile._interp(c[13], ratio),  // mgc
			BulbProfile._interp(c[11], ratio)   // rst
		)
	}

	static integer _interp(Array<integer>? range, real ratio) {
		if (range == null) return 0
		return floor(range![0] + (range![1] - range![0]) * ratio)
	}
}
